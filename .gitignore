.idea
*.iml

# Runtime state created by init/bootstrap.sh inside ai-agent-core itself.
# tasks/todo.md and tasks/lessons.md live here so the host project stays clean.
/generated/

# Host-project-specific AI tools, skills, and resources.
# Tracked only as an empty directory (.gitkeep). Host projects that vendor
# ai-agent-core may invert this rule in their own .gitignore if they want to
# commit their customizations.
/local/*
!/local/.gitkeep
